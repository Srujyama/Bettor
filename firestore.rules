rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Chipd Firestore Security Rules.
//
// Mental model: the client can READ what it's allowed to see and can NEVER write
// money, pools, status, balances, or stats. Every money/state mutation goes
// through a Cloud Function (server-authoritative). Where a client write IS
// allowed (profile fields, comments, votes) it is tightly whitelisted and
// validated here as defense-in-depth.
//
// App Check is REQUIRED for all access. Age-gate + self-exclusion are enforced
// for write paths via a get() on the caller's user doc.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function appChecked() {
      // App Check is enforced at the PLATFORM level (Firebase console → App Check
      // → Firestore: Enforce), NOT in rules. Referencing request.app here breaks
      // every client write under the JS SDK / emulator (which don't attach an App
      // Check token → "Property app is undefined"). So this is intentionally a
      // no-op gate; un-attested clients are still blocked in production by the
      // platform setting. Keeping it as a function preserves the call sites.
      return true;
    }
    function ok() {
      return signedIn() && appChecked();
    }
    function isUser(uid) {
      return ok() && request.auth.uid == uid;
    }
    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function callerDoc() {
      return userDoc(request.auth.uid);
    }
    function ageVerified() {
      return ok() && callerDoc().ageVerified == true;
    }
    function notExcluded() {
      return ok() && (
        callerDoc().rgLimits.selfExclusionUntil == null ||
        callerDoc().rgLimits.selfExclusionUntil < request.time.toMillis()
      );
    }
    function notBanned() {
      return ok() && callerDoc().isBanned != true && callerDoc().flags.frozen != true;
    }
    function canPlay() {
      return ageVerified() && notExcluded() && notBanned();
    }
    // The exact set of fields a user may change on their own profile. This is an
    // allow-LIST, so every CF-only field is implicitly forbidden — including the
    // expansion economy fields equipped / pro / powerups / xp and the achievement
    // counters (winCount, betsCreated, …). They are NOT in the list below, so a
    // client update that touches any of them is rejected here as well as by the
    // CF-only sub-collection rules.
    function onlyProfileFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['displayName', 'photoURL', 'settings', 'locale']);
    }
    // CF-write-only user-doc fields. `engagement` (hourly/daily-spin/streak state)
    // joins the existing forbidden set (equipped / pro / powerups / xp / stat
    // counters): it is NOT in onlyProfileFields(), so the allow-LIST already blocks
    // it, and this explicit guard documents + double-locks it as defense-in-depth.
    function noEngagementWrite() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['engagement']);
    }
    // True if the caller is a member of the given crew (group).
    function isCrewMember(groupId) {
      return ok()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Profiles are readable by any signed-in (App Checked) user (social app).
      allow read: if ok();
      // Creation is server-only (onUserCreate). Never client-created.
      allow create: if false;
      // Owners may patch ONLY their profile whitelist — never money/stats/compliance/engagement.
      allow update: if isUser(uid) && onlyProfileFields() && noEngagementWrite();
      allow delete: if false;

      // Subcollections.
      match /friends/{friendUid} {
        allow read: if isUser(uid);
        // Friendship edges are mirrored by Cloud Functions only.
        allow write: if false;
      }
      match /feed/{itemId} {
        allow read: if isUser(uid);
        // Owner may mark items read; everything else is server-written.
        allow update: if isUser(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
      match /notifications/{notifId} {
        allow read: if isUser(uid);
        allow update: if isUser(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
      match /devices/{deviceId} {
        // Device tokens are owner-private; registered via Cloud Function.
        allow read: if isUser(uid);
        allow write: if false;
      }
      match /achievements/{achievementId} {
        allow read: if isUser(uid);
        allow write: if false;
      }
      match /rg_events/{eventId} {
        allow read: if isUser(uid);
        allow write: if false;
      }

      // ── expansion: missions / inventory / wrapped (CF-write only) ────────────
      match /missions/{missionId} {
        // Daily/weekly quest progress — owner reads; claimMission CF writes.
        allow read: if isUser(uid);
        allow write: if false;
      }
      match /inventory/{itemId} {
        // Owned cosmetics — owner reads; buyCosmetic/equipCosmetic CFs write.
        allow read: if isUser(uid);
        allow write: if false;
      }
      match /wrapped/{periodId} {
        // Personal "wrapped" recap — owner reads; generateWrapped CF writes.
        allow read: if isUser(uid);
        allow write: if false;
      }

      // ── casino game rounds (provably-fair; CF-write only) ────────────────────
      match /gameRounds/{roundId} {
        // Owner reads their own round history; playGame CF is the only writer.
        allow read: if isUser(uid);
        allow write: if false;
      }
    }

    // ── handles (unique username registry) ─────────────────────────────────────
    match /handles/{handle} {
      allow read: if ok();
      // Create-once: only the owner can claim a free handle for themselves.
      allow create: if ok()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── ledgers (financial-grade, append-only) ─────────────────────────────────
    match /ledgers/{uid}/entries/{entryId} {
      // Read-own-only. NEVER client-writable.
      allow read: if isUser(uid);
      allow write: if false;
    }

    // ── bets ───────────────────────────────────────────────────────────────────
    match /bets/{betId} {
      // Readable by any signed-in user (visibility filtering is a UX concern; the
      // pilot keeps bets broadly readable). Tighten per-visibility later.
      allow read: if ok();

      // Bets are created by the createBet Cloud Function. We permit a direct
      // create ONLY when it is the caller's own bet, they are age-verified, and
      // the doc starts in a safe zero-money 'open' state — but the canonical path
      // is the CF. Prefer createBet. Money/status fields must be pristine.
      allow create: if false;

      // No client status/money/pool writes ever.
      allow update, delete: if false;

      // ── entries (escrow records) ─────────────────────────────────────────────
      match /entries/{uid} {
        // Participants list is readable by signed-in users.
        allow read: if ok();
        // placeBet / cancelEntry Cloud Functions only.
        allow write: if false;
      }

      // ── votes (consensus) ────────────────────────────────────────────────────
      match /votes/{uid} {
        allow read: if ok();
        // voteOutcome CF writes these; deny direct client writes so the
        // participant/threshold checks can't be bypassed.
        allow write: if false;
      }

      // ── disputes ─────────────────────────────────────────────────────────────
      match /disputes/{disputeId} {
        allow read: if ok();
        // raiseDispute CF only.
        allow write: if false;
      }

      // ── comments ─────────────────────────────────────────────────────────────
      match /comments/{commentId} {
        allow read: if ok();
        // postComment CF is the canonical path (rate-limit + identity). Deny
        // direct client writes.
        allow write: if false;
      }

      // ── settlement result (immutable) ────────────────────────────────────────
      match /settlement/{docId} {
        allow read: if ok();
        allow write: if false;
      }
    }

    // ── groups ───────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      // Members may read their group; for the pilot, groups are discoverable by
      // any signed-in user (invite codes gate joining).
      allow read: if ok();
      allow write: if false; // createGroup / joinGroup CFs only.

      match /members/{uid} {
        // Members can see the roster of groups they belong to.
        allow read: if ok();
        allow write: if false;
      }

      // ── crew chat (expansion) ────────────────────────────────────────────────
      match /chat/{messageId} {
        // Only crew members may read the thread.
        allow read: if isCrewMember(groupId);
        // The sendChat CF is the canonical path (rate-limit + identity + bet-ref
        // validation). We additionally permit a direct create by an authed crew
        // member, defensively rate-limited: the doc must be authored by the
        // caller, server-stamped within a few seconds of now, and money-free.
        allow create: if isCrewMember(groupId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.groupId == groupId
          && request.resource.data.createdAt is int
          && request.resource.data.createdAt <= request.time.toMillis() + 5000
          && request.resource.data.createdAt >= request.time.toMillis() - 5000
          && (!('text' in request.resource.data) || request.resource.data.text.size() <= 500);
        allow update, delete: if false;
      }
    }

    // ── leaderboards (server-computed, read-only) ──────────────────────────────
    match /leaderboards/{document=**} {
      allow read: if ok();
      allow write: if false;
    }

    // ── config / remote flags (read-only to clients) ───────────────────────────
    match /config/{flagId} {
      allow read: if ok();
      allow write: if false;
    }

    // ── seasons + standings (server-computed, read-all) ─────────────────────────
    match /seasons/{seasonId} {
      allow read: if ok();
      allow write: if false; // rollSeason / refreshSeasonStandings CFs only.

      match /standings/{standingUid} {
        // Public competitive board within a season.
        allow read: if ok();
        allow write: if false;
      }
    }

    // ── fixtures (sports oracle data, read-all, CF/scheduled-write only) ─────────
    match /fixtures/{fixtureId} {
      allow read: if ok();
      // syncFixtures / updateLiveScores scheduled functions are the ONLY writers.
      allow write: if false;
    }

    // ── parlays (multi-leg slips; created via createParlay CF) ───────────────────
    match /parlays/{slipId} {
      // Owner reads their slip; public slips are readable by any signed-in user.
      // Clients can NEVER write money fields (stake/multiplier/payout/status) — the
      // createParlay CF and oracleResolve own the whole doc.
      allow read: if ok() && (
        resource.data.uid == request.auth.uid ||
        resource.data.visibility == 'public' ||
        !('visibility' in resource.data)
      );
      allow write: if false;
    }

    // ── brackets (single-elim pools; created via createBracket CF) ───────────────
    match /brackets/{bracketId} {
      // Discoverable to signed-in users; entry fees / pool / winners are CF-written.
      allow read: if ok();
      allow write: if false;
    }

    // ── squares (grid games; created via createSquaresGame CF) ───────────────────
    match /squares/{gameId} {
      // Public/participant-readable; claimSquare CF writes cells and money fields.
      allow read: if ok();
      allow write: if false;
    }

    // ── rivalries (head-to-head; updated by onBetSettled trigger) ────────────────
    match /rivalries/{pairId} {
      // Readable only by the two participants of the rivalry.
      allow read: if ok() && (
        resource.data.uidA == request.auth.uid ||
        resource.data.uidB == request.auth.uid
      );
      allow write: if false;
    }

    // ── prediction markets (LMSR AMM; created/traded via CFs) ───────────────────
    match /markets/{marketId} {
      // Public read (markets are a discovery surface). All AMM state, prices,
      // volume, status and resolution are CF-written (createMarket / tradeMarket /
      // resolveMarket) — clients can NEVER write money/odds.
      allow read: if ok();
      allow write: if false;

      // ── positions (per-trader holdings + P/L) ────────────────────────────────
      match /positions/{positionUid} {
        // Public read for the holders/leaderboard view; tradeMarket CF writes.
        allow read: if ok();
        allow write: if false;
      }

      // ── trades (immutable AMM fills) ─────────────────────────────────────────
      match /trades/{tradeId} {
        // Public tape; tradeMarket CF appends. Never client-writable.
        allow read: if ok();
        allow write: if false;
      }
    }

    // ── discovery feed (denormalized; CF/scheduled-write only) ──────────────────
    match /discovery/{itemId} {
      // Read by all signed-in users — the TikTok-style discovery pager.
      allow read: if ok();
      allow write: if false;
    }

    // ── server-only collections (idempotency, reconciliation) ──────────────────
    match /idempotency/{key} {
      allow read, write: if false;
    }
    match /reconciliation/{day} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── default deny ───────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
