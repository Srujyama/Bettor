# Chipd — environment contract. Copy to .env (gitignored) and fill in.
# These EXPO_PUBLIC_* values are the Firebase WEB config. They are NOT secrets
# (they ship in the client by design); access is protected by Firestore Security
# Rules + App Check, not by hiding these keys.
#
# Get them from: Firebase Console → Project settings → General → Your apps → Web app.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App Check (web reCAPTCHA v3 site key). Optional for emulator/dev.
EXPO_PUBLIC_FIREBASE_RECAPTCHA_SITE_KEY=

# Set to "1" to point the app at the local Firebase Emulator Suite instead of prod.
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=1
# Host the emulators are reachable at from the device/simulator.
# iOS simulator + web: localhost. Android emulator: 10.0.2.2. Physical device: your LAN IP.
EXPO_PUBLIC_EMULATOR_HOST=localhost

# Cloud Functions region (close to Macau).
EXPO_PUBLIC_FUNCTIONS_REGION=asia-east2

# EAS / build
EAS_PROJECT_ID=
APP_VARIANT=development
