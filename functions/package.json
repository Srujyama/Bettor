{
  "name": "chipd-functions",
  "version": "1.0.0",
  "description": "Chipd server-authoritative backend — Cloud Functions (gen2). Settlement math is atomic, idempotent, and server-only.",
  "main": "lib/index.js",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test:unit": "jest --config jest.rules.config.js test/ledger.test.ts",
    "test:rules": "firebase emulators:exec --only firestore 'jest --config jest.rules.config.js'",
    "test:fns": "firebase emulators:exec --only firestore,functions 'jest --config jest.rules.config.js test/placeBet.int.test.ts'",
    "test:integrity": "firebase emulators:exec --only firestore 'jest --config jest.rules.config.js'"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^29.5.14",
    "firebase": "^12.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.4"
  }
}
